# =============================================================================
# Intake24 API Server Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed
# Required variables are marked with [REQUIRED]
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Intake24
APP_ICON=
APP_POWERED_BY=

APP_HOST=localhost
APP_PORT=3100
APP_SECRET=                        # [REQUIRED] Secret for admin login generation/verification

DEV_HTTPS=false
DEV_MKCERT_PATH=                   # Path to mkcert certificates for local HTTPS

APP_URL_BASE=http://localhost:3100
APP_URL_ADMIN=/admin
APP_URL_DOCS=/docs
APP_URL_SURVEY=/survey
APP_URL_IMAGES=http://localhost:3100/images

# -----------------------------------------------------------------------------
# ACL Settings
# -----------------------------------------------------------------------------
ACL_CACHE_ENABLED=true
ACL_CACHE_TTL=7d

ACL_SIGNUP_ENABLED=true
ACL_SIGNUP_ROLES=researcher
ACL_SIGNUP_PERMISSIONS=            # Comma-delimited list of permissions for new signups

# -----------------------------------------------------------------------------
# Redis Settings (Common defaults - can be overridden per-service below)
# -----------------------------------------------------------------------------
REDIS_URL=                         # Connection URL (alternative to host/port)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0

# -----------------------------------------------------------------------------
# Cache Settings
# -----------------------------------------------------------------------------
CACHE_REDIS_URL=                   # Override Redis URL for cache
CACHE_REDIS_HOST=localhost
CACHE_REDIS_PORT=6379
CACHE_REDIS_DATABASE=0
CACHE_REDIS_PREFIX=it24:cache:
CACHE_TTL=7d
CACHE_SURVEY_SETTINGS_TTL=120s

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
DB_CONNECTION_SSL=true             # Database connection SSL (PostgreSQL only)

# System database connection info
DB_DEV_SYSTEM_URL=postgres://user:password@localhost:5432/intake24_system_dev
DB_DEV_SYSTEM_DRIVER=postgres
# DB_DEV_SYSTEM_HOST=localhost
# DB_DEV_SYSTEM_PORT=5432
# DB_DEV_SYSTEM_DATABASE=intake24_system_dev
# DB_DEV_SYSTEM_USERNAME=intake24
# DB_DEV_SYSTEM_PASSWORD=
DB_DEV_SYSTEM_DEBUG_QUERY_LIMIT=

# Foods database connection info
DB_DEV_FOODS_URL=postgres://user:password@localhost:5432/intake24_foods_dev
DB_DEV_FOODS_DRIVER=postgres
# DB_DEV_FOODS_HOST=localhost
# DB_DEV_FOODS_PORT=5432
# DB_DEV_FOODS_DATABASE=intake24_foods_dev
# DB_DEV_FOODS_USERNAME=intake24
# DB_DEV_FOODS_PASSWORD=
DB_DEV_FOODS_DEBUG_QUERY_LIMIT=

# -----------------------------------------------------------------------------
# Filesystem Settings
# -----------------------------------------------------------------------------
FS_PUBLIC=public
FS_DOWNLOADS=storage/downloads
FS_UPLOADS=storage/uploads
FS_IMAGES=storage/images

# -----------------------------------------------------------------------------
# Logging Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_DIR=storage/logs

# -----------------------------------------------------------------------------
# Mail Settings
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp                   # Options: smtp, log
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SECURE=false
MAIL_IGNORE_TLS=true
MAIL_FROM_ADDRESS=no-reply@domain.com
MAIL_FROM_NAME=$APP_NAME
MAIL_REPLY_TO_ADDRESS=             # Optional reply-to address

# -----------------------------------------------------------------------------
# Queue Settings (BullMQ)
# -----------------------------------------------------------------------------
QUEUE_REDIS_URL=                   # Override Redis URL for queue
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_DATABASE=0
QUEUE_WORKERS=3

# -----------------------------------------------------------------------------
# Redis PubSub Settings (for food index builder)
# -----------------------------------------------------------------------------
PUB_SUB_CHANNEL_NAME=index-builder
PUBLISHER_REDIS_URL=
PUBLISHER_REDIS_HOST=localhost
PUBLISHER_REDIS_PORT=6379
PUBLISHER_REDIS_DATABASE=0
SUBSCRIBER_REDIS_URL=
SUBSCRIBER_REDIS_HOST=localhost
SUBSCRIBER_REDIS_PORT=6379
SUBSCRIBER_REDIS_DATABASE=0

# -----------------------------------------------------------------------------
# Rate Limiter Settings
# -----------------------------------------------------------------------------
RATE_LIMITER_REDIS_URL=            # Override Redis URL for rate limiter
RATE_LIMITER_REDIS_HOST=localhost
RATE_LIMITER_REDIS_PORT=6379
RATE_LIMITER_REDIS_DATABASE=0
RATE_LIMITER_REDIS_PREFIX=it24:rate-limiter:

# Generic API rate limiting
RATE_LIMITER_GENERIC_WINDOW=5m
RATE_LIMITER_GENERIC_LIMIT=300

# Authentication rate limiting
RATE_LIMITER_LOGIN_WINDOW=15m
RATE_LIMITER_LOGIN_LIMIT=5
RATE_LIMITER_PASSWORD_WINDOW=5m
RATE_LIMITER_PASSWORD_LIMIT=1
RATE_LIMITER_VERIFY_WINDOW=5m
RATE_LIMITER_VERIFY_LIMIT=1
RATE_LIMITER_GEN_USER_WINDOW=5m
RATE_LIMITER_GEN_USER_LIMIT=1

# Feature rate limiting
RATE_LIMITER_FEEDBACK_WINDOW=1m
RATE_LIMITER_FEEDBACK_LIMIT=1
RATE_LIMITER_RATING_WINDOW=15m
RATE_LIMITER_RATING_LIMIT=1

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------

# CORS settings (comma-delimited list)
CORS_ORIGIN=http://localhost:8100,http://localhost:8200

# Proxy settings (comma-delimited list)
PROXY=loopback

# -----------------------------------------------------------------------------
# JSON Web Token (JWT) Settings
# -----------------------------------------------------------------------------
JWT_ISSUER=intake24
JWT_ACCESS_SECRET=                 # [REQUIRED] Secret for signing access tokens

# Admin JWT settings
JWT_ADMIN_ACCESS_LIFETIME=15m
JWT_ADMIN_REFRESH_SECRET=          # [REQUIRED] Secret for signing admin refresh tokens
JWT_ADMIN_REFRESH_LIFETIME=1d
JWT_ADMIN_COOKIE_PATH=/api/admin/auth
JWT_ADMIN_COOKIE_SAMESITE=lax      # Options: strict, lax, none
JWT_ADMIN_COOKIE_SECURE=true

# Survey JWT settings
JWT_SURVEY_ACCESS_LIFETIME=15m
JWT_SURVEY_REFRESH_SECRET=         # [REQUIRED] Secret for signing survey refresh tokens
JWT_SURVEY_REFRESH_LIFETIME=1d
JWT_SURVEY_COOKIE_PATH=/api/auth
JWT_SURVEY_COOKIE_SAMESITE=lax     # Options: strict, lax, none
JWT_SURVEY_COOKIE_SECURE=true

# -----------------------------------------------------------------------------
# Session Settings
# -----------------------------------------------------------------------------
SESSION_REDIS_URL=                 # Override Redis URL for sessions
SESSION_REDIS_HOST=localhost
SESSION_REDIS_PORT=6379
SESSION_REDIS_DATABASE=0
SESSION_REDIS_PREFIX=it24:session:
SESSION_COOKIE_NAME=it24_session
SESSION_COOKIE_LIFETIME=15m
SESSION_COOKIE_PATH=/api/admin
SESSION_COOKIE_SAME_SITE=lax       # Options: strict, lax, none
SESSION_COOKIE_SECURE=true

# -----------------------------------------------------------------------------
# Multi-Factor Authentication (MFA) Settings
# -----------------------------------------------------------------------------

# DUO MFA provider settings
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=
DUO_REDIRECT_URL=http://localhost:3100/admin

# FIDO2/WebAuthn settings
FIDO_ISSUER=intake24

# OTP (TOTP) settings
OTP_ISSUER=intake24

# -----------------------------------------------------------------------------
# Password & Auth Token Settings
# -----------------------------------------------------------------------------
PASSWORDS_EXPIRES_IN=1h            # Password reset token expiry
AUTH_TOKENS_SIZE=32                # Size of generated auth tokens
AUTH_TOKENS_ALPHABET=              # Custom alphabet for tokens (null = default)
SIGN_IN_LOG_ENABLED=true           # Enable sign-in logging

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------

# Captcha settings (hCaptcha or reCAPTCHA)
CAPTCHA_PROVIDER=                  # Options: h-captcha, re-captcha
CAPTCHA_SECRET=

# Web Push notifications
WEBPUSH_SUBJECT=mailto:example@domain.com
WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# OpenSearch Settings
# -----------------------------------------------------------------------------
OPENSEARCH_HOST=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX_PREFIX=intake24_
OPENSEARCH_BATCH_SIZE=500

# Japanese food search index
OPENSEARCH_JAPANESE_INDEX=intake24_foods_ja

# Japanese neural search settings (optional - for semantic search)
OPENSEARCH_JAPANESE_SEARCH_PIPELINE=
OPENSEARCH_JAPANESE_NEURAL_MODEL_ID=
OPENSEARCH_JAPANESE_NEURAL_FIELD=embedding
OPENSEARCH_JAPANESE_NEURAL_K=100
OPENSEARCH_JAPANESE_NEURAL_BOOST=
OPENSEARCH_JAPANESE_INGEST_PIPELINE=

# Hybrid search settings (optional - combines keyword + semantic search)
OPENSEARCH_ENABLE_HYBRID_SEARCH=false
OPENSEARCH_EMBEDDING_DIMENSION=768
OPENSEARCH_EMBEDDING_FIELD=embedding
OPENSEARCH_KNN_K=100
OPENSEARCH_KNN_BOOST=50

# Reciprocal Rank Fusion (RRF) settings
OPENSEARCH_USE_RRF=false
OPENSEARCH_RRF_RANK_CONSTANT=60
OPENSEARCH_RRF_WINDOW_SIZE=100
OPENSEARCH_RRF_SEARCH_PIPELINE=rrf-pipeline

# -----------------------------------------------------------------------------
# AWS SageMaker Settings (for Japanese Ruri model)
# -----------------------------------------------------------------------------
SAGEMAKER_RURI_ENDPOINT=           # SageMaker endpoint for Ruri embedding model
SAGEMAKER_RURI_REGION=ap-northeast-1

# -----------------------------------------------------------------------------
# OpenAI Settings (optional - for AI-powered features)
# -----------------------------------------------------------------------------
OPENAI_EMBEDDING_ENABLED=false
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_REQUESTS_PER_MINUTE=5000
OPENAI_MAX_TOKENS_PER_MINUTE=2000000
OPENAI_EMBEDDING_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# OpenRouter AI Settings (optional - for AI-powered synonym suggestions)
# Get your API key at: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_REQUESTS_PER_MINUTE=60
OPENROUTER_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Image Processing Settings
# -----------------------------------------------------------------------------
IMAGE_SOURCE_THUMB_WIDTH=768
IMAGE_SOURCE_THUMB_HEIGHT=432
IMAGE_AS_SERVED_WIDTH=1000
IMAGE_AS_SERVED_THUMB_WIDTH=200
IMAGE_MAP_WIDTH=1000
IMAGE_DRINK_SCALE_WIDTH=1000
IMAGE_OPTION_SELECTION_WIDTH=300
IMAGE_OPTION_SELECTION_HEIGHT=200
IMAGE_FOOD_THUMB_WIDTH=1000

# -----------------------------------------------------------------------------
# PDF Generation Settings (Puppeteer)
# -----------------------------------------------------------------------------
PUPPETEER_HEADLESS=true            # Options: true, false, 'new'
PUPPETEER_LANG=                    # Browser language setting
