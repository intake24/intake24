  "scripts": {
    "postinstall": "pnpm unrun scripts/clean-puppeteer-cache.ts",
    "build-only": "tsdown",
    "build": "pnpm run typecheck && pnpm run build-only",
    "start": "node ./dist/server.mjs",
    "dev": "tsdown --watch --onSuccess \"pnpm run dev:start\"",
    "dev:start": "concurrently -c blue,red --names API,TS \"node --trace-warnings --inspect=5959 ./dist/server.mjs\" \"pnpm run typecheck\"",
    "test:unit": "vitest",
    "test:unit:debug": "vitest --inspect-brk --no-file-parallelism --test-timeout=0",
    "test:integration": "vitest ./__tests__/integration/index.test.ts --config vitest.integration.config.ts",
    "test:integration:debug": "vitest --inspect-brk --no-file-parallelism --test-timeout=0 ./__tests__/integration/index.test.ts --config vitest.integration.config.ts",
    "typecheck": "tsgo --noEmit"
  },
