# =============================================================================
# Intake24 Database Package Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed
# This configuration is used for database migrations and direct DB access
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Security
# -----------------------------------------------------------------------------
DB_CONNECTION_SSL=true             # Database connection SSL (PostgreSQL only)

# =============================================================================
# DEVELOPMENT DATABASES
# =============================================================================

# -----------------------------------------------------------------------------
# Development System Database
# -----------------------------------------------------------------------------
DB_DEV_SYSTEM_URL=postgres://user:password@localhost:5432/intake24_system_dev
DB_DEV_SYSTEM_DRIVER=postgres
# DB_DEV_SYSTEM_HOST=localhost
# DB_DEV_SYSTEM_PORT=5432
# DB_DEV_SYSTEM_DATABASE=intake24_system_dev
# DB_DEV_SYSTEM_USERNAME=intake24
# DB_DEV_SYSTEM_PASSWORD=
DB_DEV_SYSTEM_DEBUG_QUERY_LIMIT=

# -----------------------------------------------------------------------------
# Development Foods Database
# -----------------------------------------------------------------------------
DB_DEV_FOODS_URL=postgres://user:password@localhost:5432/intake24_foods_dev
DB_DEV_FOODS_DRIVER=postgres
# DB_DEV_FOODS_HOST=localhost
# DB_DEV_FOODS_PORT=5432
# DB_DEV_FOODS_DATABASE=intake24_foods_dev
# DB_DEV_FOODS_USERNAME=intake24
# DB_DEV_FOODS_PASSWORD=
DB_DEV_FOODS_DEBUG_QUERY_LIMIT=

# =============================================================================
# TEST DATABASES
# =============================================================================

# -----------------------------------------------------------------------------
# Test System Database
# -----------------------------------------------------------------------------
DB_TEST_SYSTEM_URL=postgres://user:password@localhost:5432/intake24_system_test
DB_TEST_SYSTEM_DRIVER=postgres
# DB_TEST_SYSTEM_HOST=localhost
# DB_TEST_SYSTEM_PORT=5432
# DB_TEST_SYSTEM_DATABASE=intake24_system_test
# DB_TEST_SYSTEM_USERNAME=intake24
# DB_TEST_SYSTEM_PASSWORD=
DB_TEST_SYSTEM_DEBUG_QUERY_LIMIT=

# -----------------------------------------------------------------------------
# Test Foods Database
# -----------------------------------------------------------------------------
DB_TEST_FOODS_URL=postgres://user:password@localhost:5432/intake24_foods_test
DB_TEST_FOODS_DRIVER=postgres
# DB_TEST_FOODS_HOST=localhost
# DB_TEST_FOODS_PORT=5432
# DB_TEST_FOODS_DATABASE=intake24_foods_test
# DB_TEST_FOODS_USERNAME=intake24
# DB_TEST_FOODS_PASSWORD=
DB_TEST_FOODS_DEBUG_QUERY_LIMIT=

# =============================================================================
# PRODUCTION DATABASES
# =============================================================================

# -----------------------------------------------------------------------------
# Production System Database
# -----------------------------------------------------------------------------
DB_SYSTEM_URL=postgres://user:password@localhost:5432/intake24_system
DB_SYSTEM_DRIVER=postgres
# DB_SYSTEM_HOST=localhost
# DB_SYSTEM_PORT=5432
# DB_SYSTEM_DATABASE=intake24_system
# DB_SYSTEM_USERNAME=intake24
# DB_SYSTEM_PASSWORD=
DB_SYSTEM_DEBUG_QUERY_LIMIT=

# -----------------------------------------------------------------------------
# Production Foods Database
# -----------------------------------------------------------------------------
DB_FOODS_URL=postgres://user:password@localhost:5432/intake24_foods
DB_FOODS_DRIVER=postgres
# DB_FOODS_HOST=localhost
# DB_FOODS_PORT=5432
# DB_FOODS_DATABASE=intake24_foods
# DB_FOODS_USERNAME=intake24
# DB_FOODS_PASSWORD=
DB_FOODS_DEBUG_QUERY_LIMIT=
